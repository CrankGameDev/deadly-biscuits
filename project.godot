; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Basilisk Biskuits"
run/main_scene="uid://bia5rf3vkvbx7"
config/custom_user_dir_name="basilisk_biskuits"
config/project_settings_override="user://engine_settings.cfg"
config/features=PackedStringArray("4.7", "Forward Plus")
boot_splash/use_filter=false
boot_splash/image="uid://odjsgxnv3k8p"
config/icon="res://assets/icons/godot_icon.svg"
config/settings_file="user://game_settings.cfg"

[audio]

buses/default_bus_layout="uid://dqyfynkwycinu"

[autoload]

GameSettings="*uid://1sx8cu4w3f43"
ResourceCache="*uid://cfwb0ima7db57"
SceneManager="*res://core/global/SceneManager.gd"
LevelManager="*res://core/global/LevelManager.gd"
Persistence="*res://core/global/Persistence.gd"
Dialogic="*uid://ds2q0uclmolvu"

[dialogic]

